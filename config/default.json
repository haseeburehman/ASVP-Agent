{
  "server": {
    "mode": "http",
    "url": "https://management.example.invalid",
    "registrationPath": "/api/agents/register",
    "heartbeatPath": "/api/agents/heartbeat",
    "tasksPath": "/api/agents/tasks/poll",
    "resultsPath": "/api/agents/results",
    "adminToken": null,
        "enrollmentToken": null,
        "requestTimeoutMs": 10000
  },
  "agent": {
    "heartbeatIntervalMs": 30000,
    "pollIntervalMs": 10000,
    "logLevel": "info"
  },
  "dashboard": {
    "enabled": false,
    "port": 4180,
    "bindAddress": "127.0.0.1"
  },
  "storage": {
    "identityPath": "var/identity.json",
    "statusPath": "var/status.json",
    "queueDir": "var/queue",
    "maxQueueSizeBytes": 524288000,
    "maxQueueItems": 10000,
    "maxItemAgeMs": 604800000
  },
  "retry": {
    "initialDelayMs": 1000,
    "maximumDelayMs": 30000
  },
  "collectors": {
    "upload": {
      "intervalMs": 15000,
      "uploadConcurrency": 3,
      "maxPayloadWarningBytes": 10485760,
      "authFailureThreshold": 5
    },
    "noop": {
      "timeoutMs": 5000,
      "concurrency": 2
    },
    "os-info": {
      "timeoutMs": 25000,
      "concurrency": 1,
      "patchCheckTimeoutMs": 15000
    },
    "apps": {
      "timeoutMs": 20000,
      "concurrency": 1,
      "maxItems": 500
    },
    "sca-deps": {
      "timeoutMs": 30000,
      "concurrency": 1,
      "scanPaths": [],
      "maxDepth": 6,
      "maxManifests": 200
    },
    "containers": {
      "timeoutMs": 60000,
      "concurrency": 1,
      "maxContainers": 20,
      "maxPackagesPerContainer": 500
    },
    "network-scan": {
      "allowedCidrs": [],
      "maxCidrSize": 16,
      "allowWideRanges": false,
      "timeoutMs": 120000,
      "concurrency": 1,
      "maxConcurrentTargets": 5,
      "maxConcurrentPortsPerHost": 50,
      "maxPortsPerHost": 1000,
      "perHostDelayMs": 100,
      "perPortTimeoutMs": 1000,
      "bannerTimeoutMs": 2000,
      "maxBannerBytes": 1024,
      "maxScanOperationsPerTask": 100000
    },
    "tls-checks": {
      "allowedCidrs": [],
      "maxCidrSize": 16,
      "allowWideRanges": false,
      "timeoutMs": 180000,
      "concurrency": 1,
      "maxConcurrentTargets": 5,
      "maxPortsPerHost": 1000,
      "perHostDelayMs": 100,
      "perHandshakeTimeoutMs": 5000,
      "nmapTimeoutMs": 15000,
      "expiryWarningDays": 30,
      "maxScanOperationsPerTask": 100000
    },
    "compliance-checks": {
      "timeoutMs": 45000,
      "concurrency": 1,
      "commandTimeoutMs": 20000
    },
    "users-groups": {
      "timeoutMs": 15000,
      "concurrency": 1
    },
    "antivirus-status": {
      "timeoutMs": 20000,
      "concurrency": 1
    },
    "baseline": {
      "rescanIntervalMs": 86400000
    }
  }
}
