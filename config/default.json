{
  "server": {
    "mode": "mock",
    "url": "mock://local-management-server",
    "registrationPath": "/api/agents/register",
    "heartbeatPath": "/api/agents/heartbeat",
    "tasksPath": "/api/agents/tasks/poll",
    "requestTimeoutMs": 10000
  },
  "agent": {
    "heartbeatIntervalMs": 30000,
    "pollIntervalMs": 10000,
    "logLevel": "info"
  },
  "storage": {
    "identityPath": "var/identity.json",
    "statusPath": "var/status.json"
  },
  "retry": {
    "initialDelayMs": 1000,
    "maximumDelayMs": 30000
  },
  "collectors": {
    "noop": {
      "timeoutMs": 5000,
      "concurrency": 2
    },
    "os-info": {
      "timeoutMs": 10000,
      "concurrency": 1
    },
    "apps": {
      "timeoutMs": 20000,
      "concurrency": 1,
      "maxItems": 500
    },
    "sca-deps": {
      "timeoutMs": 30000,
      "concurrency": 1,
      "scanPaths": [],
      "maxDepth": 6,
      "maxManifests": 200
    },
    "containers": {
      "timeoutMs": 60000,
      "concurrency": 1,
      "maxContainers": 20,
      "maxPackagesPerContainer": 500
    },
    "network-scan": {
      "allowedCidrs": [],
      "maxCidrSize": 16,
      "allowWideRanges": false,
      "maxConcurrentTargets": 5,
      "maxPortsPerHost": 1000,
      "perHostDelayMs": 100,
      "perPortTimeoutMs": 1000,
      "maxScanOperationsPerTask": 100000
    }
  }
}
