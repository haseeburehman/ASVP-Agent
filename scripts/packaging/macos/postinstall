#!/bin/sh
set -eu
chmod 0755 '/Library/Application Support/ASVP Agent/asvp-agent'
mkdir -p '/Library/Application Support/ASVP Agent/var'
chmod 0700 '/Library/Application Support/ASVP Agent/var'
printf '%s\n' 'ASVP Agent installed.' 'Enroll it with your management server, then install the service:' "  sudo '/Library/Application Support/ASVP Agent/asvp-agent' --config '/Library/Application Support/ASVP Agent/config/default.json' enroll" "  sudo '/Library/Application Support/ASVP Agent/asvp-agent' --config '/Library/Application Support/ASVP Agent/config/default.json' service install"
exit 0
